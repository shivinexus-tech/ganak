# Copy this file to .env, then add your real key to .env only.
# Never commit the .env file.
ANTHROPIC_API_KEY=

# The model can be changed without editing server code.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Set this only when the chosen host documents that one trusted proxy sits
# in front of the server. It keeps per-IP rate limiting accurate after deploy.
TRUST_PROXY=0
