# Copy this file to .env, then add your real key to .env only.
# Never commit the .env file.
ANTHROPIC_API_KEY=

# The model can be changed without editing server code.
# claude-haiku-4-5-20251001 is the cheaper option if explanations get high-volume.
ANTHROPIC_MODEL=claude-sonnet-5

PORT=3001

# Bind address. Leave unset for container hosts (binds all interfaces).
# Set 127.0.0.1 when the host puts its own proxy in front.
#HOST=127.0.0.1
ALLOWED_ORIGINS=http://localhost:5173

# Set this only when the chosen host documents that one trusted proxy sits
# in front of the server. It keeps per-IP rate limiting accurate after deploy.
TRUST_PROXY=0

# When set, callers must send this value as the x-ganak-key header.
# CORS does NOT stop curl or scripts — this is what actually protects your
# Anthropic spend once the endpoint is public. Leave empty for local dev.
API_SHARED_SECRET=

# ---------- Public developer API (/v1) ----------
# Keys for the public API. JSON array, or a bare comma-separated list for local use.
# NOTE: keys live here, not in a database — rotating one means editing this and
# restarting. Quotas are counted in memory, so they are per-process: a multi-instance
# deployment needs a shared store or each instance grants the full quota.
#API_KEYS=[{"key":"replace-me","name":"partner","quotaPerDay":1000}]
API_KEYS=

# Daily quota applied to keys that do not specify their own.
API_DEFAULT_QUOTA=1000

# Per-key burst limit, requests per minute.
API_RATE_PER_MIN=60

# Public base URL advertised in /v1/openapi.json.
#PUBLIC_API_URL=https://api.example.com
